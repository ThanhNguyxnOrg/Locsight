{
  "name": "codebase-analyzer-ui",
  "private": true,
  "version": "0.0.1",
  "description": "Desktop UI for analyzing source codebases.",
  "author": "Nguyen Tuan Thanh",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^36.5.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "4.1.12",
    "tw-animate-css": "1.3.8",
    "vite": "6.3.5"
  },
  "build": {
    "appId": "com.thanhtuan.codebaseanalyzer",
    "productName": "Codebase Analyzer",
    "artifactName": "codebase-analyzer-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "arch": [
        "x64",
        "arm64"
      ]
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
